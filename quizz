<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quiz interactif ludique</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 20px;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(135deg, #eef7ff, #fdfcff);
      color: #1f2937;
    }

    .quiz-container {
      max-width: 850px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 22px;
      padding: 24px;
      box-shadow: 0 12px 35px rgba(0, 0, 0, 0.12);
      border: 1px solid #dbe7f3;
    }

    .quiz-title {
      margin: 0 0 8px 0;
      font-size: 30px;
      color: #0f172a;
    }

    .quiz-subtitle {
      margin: 0 0 18px 0;
      color: #475569;
      font-size: 15px;
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 12px;
    }

    .progress-text {
      font-weight: bold;
      color: #334155;
      font-size: 15px;
    }

    .score-mini {
      font-size: 15px;
      color: #334155;
      font-weight: bold;
    }

    .progress-track {
      width: 100%;
      height: 16px;
      background: #e5edf7;
      border-radius: 999px;
      overflow: hidden;
      margin-bottom: 22px;
      border: 1px solid #d7e3f0;
    }

    .progress-fill {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #60a5fa, #2563eb, #7c3aed);
      transition: width 0.35s ease;
    }

    .question-card {
      background: #f8fbff;
      border: 1px solid #d7e6f5;
      border-radius: 18px;
      padding: 20px;
      margin-bottom: 18px;
    }

    .question-text {
      margin: 0;
      font-size: 24px;
      line-height: 1.4;
      color: #0f172a;
    }

    .answers {
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }

    .answer-label {
      display: block;
      background: #ffffff;
      border: 2px solid #cbd5e1;
      border-radius: 14px;
      padding: 14px 16px;
      cursor: pointer;
      transition: all 0.2s ease;
      font-size: 17px;
      user-select: none;
    }

    .answer-label:hover {
      background: #eff6ff;
      border-color: #60a5fa;
      transform: translateY(-1px);
    }

    .answer-label input {
      margin-right: 10px;
      transform: scale(1.15);
    }

    .answer-label.selected {
      background: #dbeafe;
      border-color: #2563eb;
    }

    .answer-label.correct {
      background: #dcfce7;
      border-color: #16a34a;
    }

    .answer-label.incorrect {
      background: #fee2e2;
      border-color: #dc2626;
    }

    .buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 18px;
    }

    button {
      border: none;
      border-radius: 12px;
      padding: 12px 18px;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: transform 0.15s ease, opacity 0.15s ease;
    }

    button:hover {
      transform: translateY(-1px);
    }

    button:disabled {
      opacity: 0.55;
      cursor: not-allowed;
      transform: none;
    }

    .btn-validate {
      background: #2563eb;
      color: #ffffff;
    }

    .btn-next {
      background: #0f766e;
      color: #ffffff;
      display: none;
    }

    .btn-hint {
      background: #f59e0b;
      color: #ffffff;
    }

    .hint-box {
      display: none;
      margin-top: 16px;
      padding: 14px 16px;
      border-radius: 14px;
      background: #fff7ed;
      border: 2px solid #fdba74;
      color: #9a3412;
      animation: popIn 0.3s ease;
    }

    .feedback {
      margin-top: 18px;
      min-height: 110px;
      border-radius: 18px;
      padding: 18px;
      display: none;
      align-items: center;
      gap: 16px;
      animation: popIn 0.35s ease;
    }

    .feedback.good {
      background: #ecfdf5;
      border: 2px solid #86efac;
      color: #166534;
    }

    .feedback.bad {
      background: #fef2f2;
      border: 2px solid #fca5a5;
      color: #991b1b;
    }

    .feedback-icon {
      font-size: 56px;
      min-width: 70px;
      text-align: center;
      animation: bounce 0.8s ease;
    }

    .feedback-text {
      font-size: 22px;
      font-weight: bold;
      margin-bottom: 6px;
    }

    .feedback-detail {
      font-size: 15px;
      line-height: 1.45;
    }

    .results-box {
      display: none;
    }

    .result-header {
      text-align: center;
      margin-bottom: 24px;
    }

    .result-score {
      font-size: 46px;
      font-weight: bold;
      color: #0f172a;
      margin-bottom: 10px;
    }

    .result-message {
      font-size: 20px;
      color: #334155;
      margin-bottom: 16px;
    }

    .result-actions {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 26px;
    }

    .btn-restart {
      background: #7c3aed;
      color: white;
    }

    .btn-retry-wrong {
      background: #be123c;
      color: white;
    }

    .correction-list {
      display: grid;
      gap: 16px;
    }

    .correction-card {
      border: 1px solid #dbe7f3;
      border-radius: 16px;
      padding: 16px;
      background: #fbfdff;
    }

    .correction-card.good {
      border-left: 8px solid #16a34a;
    }

    .correction-card.bad {
      border-left: 8px solid #dc2626;
    }

    .correction-question {
      font-size: 19px;
      font-weight: bold;
      color: #0f172a;
      margin-bottom: 10px;
    }

    .correction-line {
      margin: 6px 0;
      font-size: 15px;
      line-height: 1.45;
      color: #334155;
    }

    .tag {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 13px;
      font-weight: bold;
      margin-bottom: 8px;
    }

    .tag.good {
      background: #dcfce7;
      color: #166534;
    }

    .tag.bad {
      background: #fee2e2;
      color: #991b1b;
    }

    @keyframes popIn {
      from {
        opacity: 0;
        transform: scale(0.96);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }

    @keyframes bounce {
      0% { transform: translateY(0); }
      25% { transform: translateY(-8px); }
      50% { transform: translateY(0); }
      75% { transform: translateY(-4px); }
      100% { transform: translateY(0); }
    }

    @media (max-width: 600px) {
      .question-text {
        font-size: 20px;
      }

      .answer-label {
        font-size: 16px;
      }

      .feedback-icon {
        font-size: 48px;
      }

      .result-score {
        font-size: 36px;
      }
    }
  </style>
</head>
<body>
  <div class="quiz-container">
    <h1 class="quiz-title">Quiz interactif</h1>
    <p class="quiz-subtitle">Réponds aux questions, demande un indice si nécessaire, puis valide.</p>

    <div id="quiz-view">
      <div class="top-bar">
        <div class="progress-text" id="progress-text"></div>
        <div class="score-mini" id="score-mini"></div>
      </div>

      <div class="progress-track">
        <div class="progress-fill" id="progress-fill"></div>
      </div>

      <div class="question-card">
        <p class="question-text" id="question-text"></p>
        <div class="answers" id="answers-container"></div>

        <div class="buttons">
          <button class="btn-hint" id="hint-btn">Indice</button>
          <button class="btn-validate" id="validate-btn">Valider</button>
          <button class="btn-next" id="next-btn">Question suivante</button>
        </div>

        <div class="hint-box" id="hint-box"></div>
        <div class="feedback" id="feedback-box">
          <div class="feedback-icon" id="feedback-icon"></div>
          <div>
            <div class="feedback-text" id="feedback-text"></div>
            <div class="feedback-detail" id="feedback-detail"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="results-box" id="results-box">
      <div class="result-header">
        <div class="result-score" id="result-score"></div>
        <div class="result-message" id="result-message"></div>
      </div>

      <div class="result-actions">
        <button class="btn-restart" id="restart-btn">Recommencer tout le quiz</button>
        <button class="btn-retry-wrong" id="retry-wrong-btn">Repasser uniquement les questions fautives</button>
      </div>

      <div class="correction-list" id="correction-list"></div>
    </div>
  </div>

  <script>
    /*
    ============================================================
    COMMENT AJOUTER DES QUESTIONS ?
    ============================================================

    Chaque question est un objet avec :

    - question : texte de la question
    - answers : tableau des réponses
    - correct : index de la bonne réponse (0 = 1re réponse, 1 = 2e, etc.)
    - explanation : explication affichée après validation et dans la correction finale
    - hint : indice que l'élève peut afficher en cliquant sur "Indice"

    Exemple :
    {
      question: "Quel est le résultat de 3 + 4 ?",
      answers: ["5", "6", "7"],
      correct: 2,
      explanation: "3 + 4 = 7.",
      hint: "Additionne 3 puis encore 4."
    }

    IMPORTANT :
    - Vous pouvez ajouter autant de questions que vous voulez.
    - Les questions et les réponses seront mélangées automatiquement.
    - Le système conserve la bonne réponse même après mélange.
    */

    const quizData = [
      {
        question: "Quelle planète est la plus proche du Soleil ?",
        answers: ["Vénus", "Mars", "Mercure", "Jupiter"],
        correct: 2,
        explanation: "Mercure est la planète la plus proche du Soleil.",
        hint: "Son nom commence par la même lettre que 'métal'."
      },
      {
        question: "Combien y a-t-il de côtés dans un triangle ?",
        answers: ["2", "3", "4", "5"],
        correct: 1,
        explanation: "Un triangle possède 3 côtés.",
        hint: "Le préfixe 'tri' donne déjà un indice."
      },
      {
        question: "Quel animal pond des œufs ?",
        answers: ["Le chat", "La poule", "Le chien", "Le cheval"],
        correct: 1,
        explanation: "La poule pond des œufs.",
        hint: "On le trouve souvent dans un poulailler."
      },
      {
        question: "Quelle est la capitale de la Belgique ?",
        answers: ["Liège", "Namur", "Bruxelles", "Anvers"],
        correct: 2,
        explanation: "La capitale de la Belgique est Bruxelles.",
        hint: "C'est aussi là que se trouvent de nombreuses institutions."
      }
    ];

    let currentQuizSet = [];
    let currentQuestionIndex = 0;
    let score = 0;
    let selectedAnswerIndex = null;
    let validated = false;
    let userResults = [];

    const progressText = document.getElementById("progress-text");
    const scoreMini = document.getElementById("score-mini");
    const progressFill = document.getElementById("progress-fill");
    const questionText = document.getElementById("question-text");
    const answersContainer = document.getElementById("answers-container");
    const validateBtn = document.getElementById("validate-btn");
    const nextBtn = document.getElementById("next-btn");
    const hintBtn = document.getElementById("hint-btn");
    const hintBox = document.getElementById("hint-box");
    const feedbackBox = document.getElementById("feedback-box");
    const feedbackIcon = document.getElementById("feedback-icon");
    const feedbackText = document.getElementById("feedback-text");
    const feedbackDetail = document.getElementById("feedback-detail");
    const quizView = document.getElementById("quiz-view");
    const resultsBox = document.getElementById("results-box");
    const resultScore = document.getElementById("result-score");
    const resultMessage = document.getElementById("result-message");
    const correctionList = document.getElementById("correction-list");
    const restartBtn = document.getElementById("restart-btn");
    const retryWrongBtn = document.getElementById("retry-wrong-btn");

    function shuffleArray(array) {
      const arr = [...array];
      for (let i = arr.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function prepareQuestion(questionObj) {
      const answersObjects = questionObj.answers.map((answerText, index) => ({
        text: answerText,
        isCorrect: index === questionObj.correct
      }));

      const shuffledAnswers = shuffleArray(answersObjects);

      return {
        question: questionObj.question,
        hint: questionObj.hint || "Pas d'indice pour cette question.",
        explanation: questionObj.explanation || "",
        answers: shuffledAnswers
      };
    }

    function startQuiz(questionSet) {
      currentQuizSet = shuffleArray(questionSet).map(prepareQuestion);
      currentQuestionIndex = 0;
      score = 0;
      selectedAnswerIndex = null;
      validated = false;
      userResults = [];

      quizView.style.display = "block";
      resultsBox.style.display = "none";

      renderQuestion();
    }

    function renderQuestion() {
      const q = currentQuizSet[currentQuestionIndex];
      selectedAnswerIndex = null;
      validated = false;

      progressText.textContent = "Question " + (currentQuestionIndex + 1) + " / " + currentQuizSet.length;
      scoreMini.textContent = "Score : " + score;
      progressFill.style.width = ((currentQuestionIndex) / currentQuizSet.length) * 100 + "%";

      questionText.textContent = q.question;
      answersContainer.innerHTML = "";
      hintBox.style.display = "none";
      hintBox.textContent = q.hint;
      feedbackBox.style.display = "none";
      feedbackBox.className = "feedback";
      nextBtn.style.display = "none";
      validateBtn.disabled = false;

      q.answers.forEach((answer, index) => {
        const label = document.createElement("label");
        label.className = "answer-label";
        label.innerHTML = `
          <input type="radio" name="answer" value="${index}">
          <span>${answer.text}</span>
        `;

        label.addEventListener("click", function () {
          if (validated) return;

          selectedAnswerIndex = index;
          document.querySelectorAll(".answer-label").forEach(el => el.classList.remove("selected"));
          label.classList.add("selected");
        });

        answersContainer.appendChild(label);
      });
    }

    function showHint() {
      hintBox.style.display = "block";
    }

    function validateAnswer() {
      if (selectedAnswerIndex === null) {
        alert("Choisis d'abord une réponse.");
        return;
      }

      if (validated) return;

      validated = true;
      validateBtn.disabled = true;
      nextBtn.style.display = "inline-block";

      const q = currentQuizSet[currentQuestionIndex];
      const labels = document.querySelectorAll(".answer-label");
      const selectedAnswer = q.answers[selectedAnswerIndex];
      const correctAnswerObj = q.answers.find(a => a.isCorrect);
      const isCorrect = selectedAnswer.isCorrect;

      labels.forEach((label, index) => {
        if (q.answers[index].isCorrect) {
          label.classList.add("correct");
        }
        if (index === selectedAnswerIndex && !q.answers[index].isCorrect) {
          label.classList.add("incorrect");
        }
      });

      if (isCorrect) {
        score++;
        scoreMini.textContent = "Score : " + score;
        feedbackBox.style.display = "flex";
        feedbackBox.className = "feedback good";
        feedbackIcon.textContent = "🐴";
        feedbackText.textContent = "Bravo !";
        feedbackDetail.textContent = q.explanation || "C'est la bonne réponse.";
      } else {
        feedbackBox.style.display = "flex";
        feedbackBox.className = "feedback bad";
        feedbackIcon.textContent = "👎";
        feedbackText.textContent = "Réponse incorrecte.";
        feedbackDetail.textContent = q.explanation || "Retiens bien la bonne réponse.";
      }

      userResults.push({
        question: q.question,
        userAnswer: selectedAnswer.text,
        correctAnswer: correctAnswerObj.text,
        isCorrect: isCorrect,
        explanation: q.explanation || "",
        hint: q.hint || ""
      });

      if (currentQuestionIndex === currentQuizSet.length - 1) {
        nextBtn.textContent = "Voir le résultat";
      } else {
        nextBtn.textContent = "Question suivante";
      }

      progressFill.style.width = ((currentQuestionIndex + 1) / currentQuizSet.length) * 100 + "%";
    }

    function nextQuestion() {
      if (currentQuestionIndex < currentQuizSet.length - 1) {
        currentQuestionIndex++;
        renderQuestion();
      } else {
        showResults();
      }
    }

    function showResults() {
      quizView.style.display = "none";
      resultsBox.style.display = "block";

      const total = currentQuizSet.length;
      const percent = Math.round((score / total) * 100);

      resultScore.textContent = score + " / " + total;

      if (percent === 100) {
        resultMessage.textContent = "Excellent. Tout est correct.";
      } else if (percent >= 75) {
        resultMessage.textContent = "Bon résultat. Quelques détails seulement sont à revoir.";
      } else if (percent >= 50) {
        resultMessage.textContent = "Résultat moyen. Il reste plusieurs points à retravailler.";
      } else {
        resultMessage.textContent = "Résultat insuffisant. Une nouvelle tentative serait utile.";
      }

      renderCorrections();

      const wrongQuestions = getWrongOriginalQuestions();
      retryWrongBtn.style.display = wrongQuestions.length > 0 ? "inline-block" : "none";
    }

    function renderCorrections() {
      correctionList.innerHTML = "";

      userResults.forEach((result, index) => {
        const card = document.createElement("div");
        card.className = "correction-card " + (result.isCorrect ? "good" : "bad");

        card.innerHTML = `
          <div class="tag ${result.isCorrect ? "good" : "bad"}">
            ${result.isCorrect ? "Correct" : "Incorrect"}
          </div>
          <div class="correction-question">
            ${index + 1}. ${result.question}
          </div>
          <div class="correction-line"><strong>Réponse donnée :</strong> ${result.userAnswer}</div>
          <div class="correction-line"><strong>Bonne réponse :</strong> ${result.correctAnswer}</div>
          <div class="correction-line"><strong>Explication :</strong> ${result.explanation || "Aucune explication fournie."}</div>
          <div class="correction-line"><strong>Indice :</strong> ${result.hint || "Aucun indice fourni."}</div>
        `;

        correctionList.appendChild(card);
      });
    }

    function getWrongOriginalQuestions() {
      const wrongQuestionTexts = userResults
        .filter(r => !r.isCorrect)
        .map(r => r.question);

      return quizData.filter(q => wrongQuestionTexts.includes(q.question));
    }

    function restartFullQuiz() {
      startQuiz(quizData);
    }

    function retryWrongQuestions() {
      const wrongQuestions = getWrongOriginalQuestions();

      if (wrongQuestions.length === 0) {
        alert("Il n'y a aucune question fautive à repasser.");
        return;
      }

      startQuiz(wrongQuestions);
    }

    hintBtn.addEventListener("click", showHint);
    validateBtn.addEventListener("click", validateAnswer);
    nextBtn.addEventListener("click", nextQuestion);
    restartBtn.addEventListener("click", restartFullQuiz);
    retryWrongBtn.addEventListener("click", retryWrongQuestions);

    startQuiz(quizData);
  </script>
</body>
</html>
